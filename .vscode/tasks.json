{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "BB nREPL",
      "type": "shell",
      "command": "mkdir -p bb && echo 16664 > bb/.nrepl-port && bb nrepl --port 16664",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Watch Unit Tests",
      "type": "shell",
      "command": "bb",
      "args": ["watch-test"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "bb-watch-test",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[RUN\\]",
          "endsPattern": "^Watching for changes"
        },
        "pattern": {
          "regexp": "^FAIL in \\((.+)\\) \\((.+):(\\d+)\\)",
          "message": 1,
          "file": 2,
          "line": 3
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Watch E2E Tests",
      "type": "shell",
      "command": "bb",
      "args": ["watch-e2e"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "bb-watch-e2e",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[RUN\\]",
          "endsPattern": "^Watching for changes"
        },
        "pattern": {
          "regexp": "^FAIL (.+)",
          "message": 1
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Dev",
      "dependsOn": ["BB nREPL", "Watch Unit Tests", "Watch E2E Tests"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
